{
  "name": "zoho-crm-devtools",
  "version": "2.0.0",
  "description": "Chrome extension that improves the Zoho CRM Deluge editor with themes, indent guides, and syntax highlighting.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/neilord/zoho-crm-devtools.git"
  },
  "bugs": {
    "url": "https://github.com/neilord/zoho-crm-devtools/issues"
  },
  "homepage": "https://chromewebstore.google.com/detail/zoho-crm-devtools/mjcppmfgjpllmmoneiaegecjlcpbfgmi",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development --outDir dist-dev",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run check && npm run typecheck && npm run test && npm run build",
    "zip": "npm run build && cd dist && zip -r ../zoho-crm-devtools.zip ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@crxjs/vite-plugin": "^2.7.0",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
